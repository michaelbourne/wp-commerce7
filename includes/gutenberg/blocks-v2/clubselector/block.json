	"editorStyle": "c7wp-clubselector",
	"supports": {
		"html": false,
		"customClassName": false
	},
	"attributes": {
		"displayType": {
			"type": "string",
			"default": "radio"
		},
		"clubs": {
			"type": "array",
			"default": []
		},
		"radioGroupName": {
			"type": "string",
			"default": ""
		}
	}
}
